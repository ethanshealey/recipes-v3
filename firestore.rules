rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Current recipe collection — public read, signed-in write
    match /recipes-v3/{slug} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Legacy collection — read-only, no writes
    match /recipes/{id} {
      allow read: if true;
      allow write: if false;
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
